{
  "manifest_version": 3,
  "name": "ExactAI",
  "version": "1.0.0",
  "description": "Extract designs pixel-perfect with AI. Replicate any design, extract CSS tokens, generate shadcn/ui components.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*",
    "https://ui.shadcn.com/*",
    "https://*.supabase.co/*",
    "https://checkout.stripe.com/*",
    "https://api.stripe.com/*",
    "https://buy.stripe.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "animation-detector.js",
        "threejs-capture.js",
        "gsap-capture.js",
        "canvas-animation-capture.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["auth-callback.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
